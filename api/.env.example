# NarrateIQ API — environment variables
# Copy to .env for local development. Set these in Railway for production.

# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard password (never commit the real value)
ADMIN_PASSWORD=change-me

# Session signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change-me

# Optional
NODE_ENV=production
PORT=3000
ALLOWED_ORIGIN=https://narrateiq.ai
